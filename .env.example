# ─── Developer DNA Environment Configuration ───
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Django ───
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── PostgreSQL ───
POSTGRES_DB=developerdna
POSTGRES_USER=devdna
POSTGRES_PASSWORD=devdna_local_pass
DATABASE_URL=postgres://devdna:devdna_local_pass@postgres:5432/developerdna

# ─── Kafka ───
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── AI / LLM ───
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
